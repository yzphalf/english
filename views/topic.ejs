<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= topic.title %> - 讨论详情</title>
  <link rel="stylesheet" href="/style.css?v=20260330" />
</head>
<body
  data-watch-endpoint="/watch/topics/<%= topic.id %>/version"
  data-watch-version="<%= watchVersion %>"
  data-watch-poll-ms="<%= watchPollMs %>"
>
  <nav class="nav-bar">
    <a href="/student?group=<%= selectedGroup %>" class="nav-brand" style="color: var(--padlet-text); font-size: 16px;">← 返回列表</a>
    <div style="display: flex; align-items: center; gap: 12px;">
      <span id="auto-refresh-indicator" class="badge">正在监控更新</span>
      <span class="badge badge-primary">Group <%= selectedGroup %></span>
    </div>
  </nav>

  <main class="container" style="max-width: 800px;">
    <div class="card" style="border-left: 4px solid var(--padlet-pink); pointer-events: none;">
      <div class="badge badge-primary" style="margin-bottom: 12px;">TOPIC</div>
      <h1 style="margin: 0 0 16px; font-size: 28px; color: #fff; font-weight: 900; letter-spacing: -0.02em;"><%= topic.title %></h1>
      <div style="line-height: 1.8; font-size: 16px; color: var(--padlet-text); opacity: 0.9; white-space: pre-wrap;"><%= topic.prompt %></div>
    </div>

    <div class="card" style="margin-top: 24px;">
      <h2 style="margin: 0 0 20px; font-size: 18px; font-weight: 800; color: #fff;">发表你的观点</h2>
      <form method="POST" action="/student/topics/<%= topic.id %>/comments">
        <input type="hidden" name="group" value="<%= selectedGroup %>" />
        <div style="margin-bottom: 16px;">
          <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:var(--padlet-muted);">你的名字</label>
          <input type="text" name="author" class="input" placeholder="输入你的名字..." required />
        </div>
        <div style="margin-bottom: 20px;">
          <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:var(--padlet-muted);">讨论内容</label>
          <textarea name="content" class="input" rows="4" placeholder="写下你的想法，开启精彩对话..." style="resize: vertical;" required></textarea>
        </div>
        <div style="text-align: right;">
          <button type="submit" class="btn btn-pink" style="padding: 12px 36px; font-size: 16px; height: 48px;">
            发送讨论 🚀
          </button>
        </div>
      </form>
    </div>

    <div style="margin: 40px 0 24px;">
      <h2 style="font-size: 18px; font-weight: 800; display: flex; align-items: center; gap: 10px; color: #fff;">
        同学们的发言 <span style="font-weight: 400; color: var(--padlet-muted);">(<%= comments.length %>)</span>
      </h2>
    </div>

    <% if (comments.length === 0) { %>
      <div style="text-align: center; padding: 60px; color: var(--padlet-muted);">
        <p style="font-size: 40px; margin-bottom: 16px;">🛋️</p>
        <p>还没有人发言，快来抢个沙发吧！</p>
      </div>
    <% } else { %>
      <div class="comment-list">
        <% comments.sort((a,b) => new Date(b.createdAt) - new Date(a.createdAt)).forEach((comment) => { %>
          <div class="comment-card">
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
              <div class="avatar" style="background: <%= ['#ff4081', '#00a2ff', '#4caf50', '#ffd602', '#9c27b0'][comment.group % 5] %>">
                <%= (comment.author || '?')[0].toUpperCase() %>
              </div>
              <div style="flex: 1;">
                <strong style="display: block; font-size: 14px; color: #fff;"><%= comment.author %></strong>
                <span style="font-size: 11px; color: var(--padlet-muted);">
                  Group <%= comment.group %> • <%= new Date(comment.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                </span>
              </div>
            </div>
            <div style="font-size: 15px; line-height: 1.7; color: var(--padlet-text); opacity: 0.95; white-space: pre-wrap; word-break: break-word;"><%= comment.content %></div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

  <script src="/auto-refresh.js"></script>
</body>
</html>
