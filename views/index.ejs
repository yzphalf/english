<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>英语讨论区</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body
  class="student-page"
  data-watch-endpoint="/watch/version"
  data-watch-version="<%= watchVersion %>"
  data-watch-poll-ms="<%= watchPollMs %>"
>
  <header class="topbar topbar-student">
    <div>
      <p class="eyebrow">English Speaking Board</p>
      <h1>英语课堂讨论（学生端）</h1>
    </div>
    <div class="top-actions">
      <span class="chip auto-refresh-chip" id="auto-refresh-indicator">实时监测中</span>
      <form method="GET" action="/student" class="top-group-form">
        <label>
          选择小组
          <select name="group" onchange="this.form.submit()">
            <% groups.forEach((group) => { %>
              <option value="<%= group %>" <%= group === selectedGroup ? 'selected' : '' %>>
                第 <%= group %> 组
              </option>
            <% }) %>
          </select>
        </label>
      </form>
    </div>
  </header>

  <main class="container student-home">
    <section class="card card-featured">
      <div class="section-head">
        <h2>讨论主题</h2>
        <span class="chip">共 <%= topics.length %> 个主题</span>
      </div>
      <p class="group-tip">当前将以第 <strong><%= selectedGroup %></strong> 组身份进入并发言。</p>
      <% if (topics.length === 0) { %>
        <p class="empty-note">暂无主题，请等待老师发布讨论题目。</p>
      <% } else { %>
        <ul class="topic-list topic-grid">
          <% topics.forEach((topic) => { %>
            <li class="topic-item">
              <a class="topic-card-link" href="/student/topics/<%= topic.id %>?group=<%= selectedGroup %>">
                <div class="topic-card-top">
                  <h3 class="topic-card-title"><%= topic.title %></h3>
                  <span class="topic-meta-pill">可参与</span>
                </div>
                <div class="topic-meta-row">
                  <span class="topic-meta-pill">讨论 <strong><%= topic.comments ? topic.comments.length : 0 %></strong></span>
                  <span class="topic-meta-pill">发布于 <%= new Date(topic.createdAt).toLocaleString() %></span>
                </div>
              </a>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </main>
  <script src="/feedback.js"></script>
  <script src="/auto-refresh.js"></script>
</body>
</html>
