<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>英语课堂讨论 - Padlet Style</title>
  <link rel="stylesheet" href="/style.css?v=20260330" />
</head>
<body
  data-watch-endpoint="/watch/version"
  data-watch-version="<%= watchVersion %>"
  data-watch-poll-ms="<%= watchPollMs %>"
>
  <nav class="nav-bar">
    <a href="/student" class="nav-brand">English Board</a>
    <div style="display: flex; align-items: center; gap: 12px;">
      <span id="auto-refresh-indicator" class="badge">实时同步中</span>
      <form method="GET" action="/student" style="margin:0;">
        <select name="group" onchange="this.form.submit()" class="input" style="width: auto; padding: 4px 12px; height: 32px;">
          <% groups.forEach((group) => { %>
            <option value="<%= group %>" <%= group === selectedGroup ? 'selected' : '' %>>第 <%= group %> 组</option>
          <% }) %>
        </select>
      </form>
    </div>
  </nav>

  <main class="container">
    <div style="margin-bottom: 32px; text-align: center;">
      <h1 style="font-size: 28px; font-weight: 900; margin-bottom: 8px;">加入讨论话题</h1>
      <p style="color: var(--padlet-muted);">你是第 <%= selectedGroup %> 组的一员，点击下方话题开始交流。</p>
    </div>

    <% if (topics.length === 0) { %>
      <div class="card" style="text-align: center; padding: 60px; border-style: dashed; border-width: 2px;">
        <p style="font-size: 40px;">🎈</p>
        <h2>暂无发布话题</h2>
        <p style="color: var(--padlet-muted);">老师还没准备好，请稍后再来看看。</p>
      </div>
    <% } else { %>
      <div class="grid">
        <% topics.forEach((topic, index) => { %>
          <a href="/student/topics/<%= topic.id %>?group=<%= selectedGroup %>" class="card" style="text-decoration:none; color:inherit;">
            <div style="height: 100px; background: <%= ['#ffecf1', '#e7f5ff', '#fff9db', '#ebfbee'][index % 4] %>; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 40px; margin-bottom: 16px;">
              <%= ['📝', '🎤', '🌟', '💬'][index % 4] %>
            </div>
            <h3 style="margin: 0 0 10px; font-size: 18px;"><%= topic.title %></h3>
            <p style="color: var(--padlet-muted); font-size: 14px; margin-bottom: 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
              <%= topic.prompt %>
            </p>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 12px; border-top: 1px solid var(--padlet-border);">
              <span class="badge badge-primary">💬 <%= topic.comments ? topic.comments.length : 0 %> 条讨论</span>
              <span style="font-size: 12px; color: #adb5bd;"><%= new Date(topic.createdAt).toLocaleDateString() %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>

  <script src="/auto-refresh.js"></script>
</body>
</html>
