<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>老师端管理面板</title>
  <link rel="stylesheet" href="/style.css?v=20260330" />
</head>
<body
  data-watch-endpoint="/watch/version"
  data-watch-version="<%= watchVersion %>"
  data-watch-poll-ms="<%= watchPollMs %>"
>
  <nav class="nav-bar">
    <div style="display:flex; flex-direction:column;">
      <span style="font-size:10px; font-weight:700; color:var(--padlet-pink); text-transform:uppercase;">Admin Dashboard</span>
      <a href="/teacher" class="nav-brand" style="color:inherit;">话题管理中心</a>
    </div>
    <div style="display:flex; align-items:center; gap:12px;">
      <span id="auto-refresh-indicator" class="badge">监控正常</span>
      <form method="POST" action="/teacher/logout" style="margin:0;">
        <button type="submit" class="btn btn-outline" style="height:32px; font-size:12px;">退出登录</button>
      </form>
    </div>
  </nav>

  <main class="container">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
      <h2 style="font-weight:900; margin:0;">讨论话题列表</h2>
      <button id="open-publish-modal" class="btn btn-pink">✨ 发布新话题</button>
    </div>

    <% if (topics.length === 0) { %>
      <div class="card" style="text-align: center; padding: 60px;">
        <p style="color:var(--padlet-muted);">还没有发布任何话题。</p>
      </div>
    <% } else { %>
      <div class="grid">
        <% topics.forEach((topic) => { %>
          <div class="card">
            <div class="card-header">
              <span class="badge <%= topic.closedAt ? 'badge-danger' : 'badge-success' %>">
                <%= topic.closedAt ? '已关闭' : '进行中' %>
              </span>
              <span style="font-size:11px; color:var(--padlet-muted);"><%= new Date(topic.createdAt).toLocaleString() %></span>
            </div>
            <h3 style="margin-bottom:12px;"><%= topic.title %></h3>
            <div style="margin-bottom:20px; font-size:13px; color:var(--padlet-muted);">已交讨论：<strong><%= topic.comments.length %></strong> 条</div>
            
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:8px;">
              <a href="/teacher/topics/<%= topic.id %>" class="btn btn-primary" style="grid-column: span 2;">实时小组监控 (Grid)</a>
              <button class="btn btn-outline qr-trigger" style="grid-column: span 2;" data-topic-id="<%= topic.id %>" data-student-link="/student/topics/<%= topic.id %>">分享二维码</button>
              
              <% if (topic.closedAt) { %>
                <form method="POST" action="/teacher/topics/<%= topic.id %>/reopen" style="grid-column: span 2; margin:0;">
                  <button type="submit" class="btn btn-outline" style="width:100%; color:var(--padlet-green); border-color:var(--padlet-green);">重启讨论话题</button>
                </form>
              <% } else { %>
                <form method="POST" action="/teacher/topics/<%= topic.id %>/close" style="grid-column: span 2; margin:0;">
                  <button type="submit" class="btn btn-outline" style="width:100%; color:var(--padlet-pink); border-color:var(--padlet-pink);">关闭讨论话题</button>
                </form>
              <% } %>
            </div>
            <form method="POST" action="/teacher/topics/<%= topic.id %>/delete" onsubmit="return confirm('彻底删除？')" style="margin:12px 0 0;">
              <button type="submit" style="width:100%; background:none; border:none; color:#666; font-size:11px; cursor:pointer; text-decoration:underline;">删除话题</button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

  <!-- Publish Modal -->
  <div id="publish-modal" class="modal-overlay" hidden>
    <div class="modal-backdrop" onclick="closeModal()"></div>
    <div class="modal-content">
      <h2 style="margin-bottom:20px;">🚀 发布话题</h2>
      <form method="POST" action="/teacher/topics">
        <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700;">话题标题</label>
        <input name="title" class="input" style="margin-bottom:16px;" placeholder="例如：English in AI Era" required />
        <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700;">引导问题</label>
        <textarea name="prompt" class="input" style="height:120px; margin-bottom:20px;" placeholder="写下讨论要求..." required></textarea>
        <div style="display:flex; justify-content:flex-end; gap:10px;">
          <button type="button" class="btn btn-outline" style="color:#999; border-color:#444;" onclick="closeModal()">取消</button>
          <button type="submit" class="btn btn-primary">立即发布</button>
        </div>
      </form>
    </div>
  </div>

  <!-- QR Modal -->
  <div id="qr-modal" class="modal-overlay" hidden>
    <div class="modal-backdrop" onclick="closeQr()"></div>
    <div class="modal-content" style="text-align:center;">
      <h2 style="margin-bottom:16px;">📱 讨论二维码</h2>
      <div class="qr-container">
        <img id="qr-img" alt="Scan to join" />
      </div>
      <p id="qr-link" style="font-size:12px; color:var(--padlet-blue); margin-bottom:20px; word-break:break-all; font-weight: 700; opacity: 0.8;"></p>
      <button class="btn btn-primary" style="width: 100%; height: 44px;" onclick="closeQr()">返回列表</button>
    </div>
  </div>

  <script>
    const modal = document.getElementById('publish-modal');
    const qrModal = document.getElementById('qr-modal');
    const qrImg = document.getElementById('qr-img');
    const qrLink = document.getElementById('qr-link');

    document.getElementById('open-publish-modal').onclick = () => { modal.hidden = false; };
    function closeModal() { modal.hidden = true; }
    function closeQr() { qrModal.hidden = true; }

    document.onkeydown = (e) => {
      if (e.key === 'Escape') { closeModal(); closeQr(); }
    };

    document.querySelectorAll('.qr-trigger').forEach(btn => {
      btn.onclick = () => {
        const tid = btn.dataset.topicId;
        const link = window.location.origin + btn.dataset.studentLink;
        qrImg.src = `/teacher/topics/${tid}/qr?link=${encodeURIComponent(link)}`;
        qrLink.innerText = link;
        qrModal.hidden = false;
      }
    });
  </script>
  <script src="/auto-refresh.js"></script>
</body>
</html>
