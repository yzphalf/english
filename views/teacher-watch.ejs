<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>讨论面板 - 全屏观看</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body
  class="teacher-page"
  data-watch-endpoint="/watch/topics/<%= topic.id %>/version"
  data-watch-version="<%= watchVersion %>"
  data-watch-poll-ms="<%= watchPollMs %>"
>
  <header class="topbar topbar-teacher">
    <div class="watch-title-block">
      <p class="eyebrow">English Speaking Board</p>
      <h1>讨论面板</h1>
      <p class="watch-submit-only">总提交人数：<strong><%= totalSubmitters %></strong></p>
    </div>
    <div class="group-badge">
      <%= selectedGroup === 'all' ? '全部同学' : ('第 ' + selectedGroup + ' 组') %>
    </div>
    <nav class="teacher-watch-nav">
      <a class="back-link" href="/teacher?topic=<%= topic.id %>&group=<%= selectedGroup %>">返回老师首页</a>
      <form method="POST" action="/teacher/logout" class="inline-form">
        <button type="submit" class="logout-btn">退出登录</button>
      </form>
    </nav>
    <span class="chip auto-refresh-chip" id="auto-refresh-indicator">实时监测中</span>
  </header>

  <main class="container watch-container">
    <section class="card">
      <div class="section-head">
        <h2>全部同学展示</h2>
      </div>
      <% if (totalComments === 0) { %>
        <p class="empty-note">当前还没有任何小组提交内容。</p>
      <% } else { %>
        <div class="group-board-grid">
          <% groupBoards.forEach((board) => { %>
            <section class="group-board">
              <div class="group-board-head">
                <h3>第 <%= board.group %> 组</h3>
                <div class="topic-meta-row group-board-stats">
                  <span class="topic-meta-pill">已交 <strong><%= board.submitterCount %></strong> 人</span>
                  <span class="topic-meta-pill">发言 <strong><%= board.commentCount %></strong> 条</span>
                </div>
              </div>
              <% if (board.comments.length === 0) { %>
                <p class="empty-note">本组暂未提交。</p>
              <% } else { %>
                <ul class="comment-list comment-list-cards">
                  <% board.comments.forEach((comment) => { %>
                    <li class="comment-item">
                      <div class="meta">
                        <strong><%= comment.author %></strong>
                        <small><%= new Date(comment.createdAt).toLocaleString() %></small>
                      </div>
                      <p><%= comment.content %></p>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </section>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>
  <script src="/feedback.js?v=20260319-2"></script>
  <script src="/auto-refresh.js?v=20260319-2"></script>
</body>
</html>
