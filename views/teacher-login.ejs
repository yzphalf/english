<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>老师登录 - English Board</title>
  <link rel="stylesheet" href="/style.css?v=20260330" />
</head>
<body style="display: flex; align-items: center; justify-content: center; min-height: 100vh;">
  <div class="container" style="max-width: 420px; width: 100%;">
    <div class="card" style="padding: 40px 32px;">
      <div style="text-align: center; margin-bottom: 32px;">
        <div style="display: inline-block; padding: 12px; background: rgba(255, 64, 129, 0.1); border-radius: 16px; margin-bottom: 16px;">
          <span style="font-size: 32px;">🔐</span>
        </div>
        <h1 style="margin: 0; font-size: 24px; font-weight: 900; color: #fff;">老师管理端</h1>
        <p style="color: var(--padlet-muted); font-size: 14px; margin-top: 8px;">请输入账号密码以继续</p>
      </div>

      <% if (error) { %>
        <div style="background: rgba(250, 82, 82, 0.1); border: 1px solid rgba(250, 82, 82, 0.3); color: #fa5252; padding: 12px; border-radius: 12px; font-size: 13px; margin-bottom: 24px; text-align: center;">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/teacher/login">
        <input type="hidden" name="next" value="<%= nextPath %>" />
        <div style="margin-bottom: 16px;">
          <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:var(--padlet-muted);">用户名</label>
          <input type="text" name="username" class="input" placeholder="请输入账号" required autofocus />
        </div>
        <div style="margin-bottom: 24px;">
          <label style="display:block; margin-bottom:8px; font-size:13px; font-weight:700; color:var(--padlet-muted);">密码</label>
          <input type="password" name="password" class="input" placeholder="请输入密码" required />
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; height: 48px; font-size: 16px;">
          立即登录
        </button>
      </form>
      
      <div style="margin-top: 32px; text-align: center;">
        <a href="/student" style="color: var(--padlet-muted); font-size: 13px; text-decoration: none;">← 返回学生端首页</a>
      </div>
    </div>
  </div>
</body>
</html>
